{
  "name": "dnd5e-discord-bot",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "build:watch": "tsc --watch --preserveWatchOutput",
    "start": "node ./dist/server.js",
    "dev": "nodemon",
    "dev:all": "sh ./commands/start_dev.sh",
    "ops:preflight": "bash ./ops/preflight.sh",
    "ops:deploy": "bash ./ops/deploy.sh",
    "ops:service": "bash ./ops/service.sh status",
    "ops:migrate-systemd": "bash ./ops/migrate_to_systemd.sh",
    "ops:pull-configs": "bash ./ops/pull_remote_configs.sh"
  },
  "author": "Julian Ranieri",
  "license": "MIT",
  "dependencies": {
    "discord-interactions": "^3.2.0",
    "dotenv": "^16.0.0",
    "express": "^4.17.3",
    "node-fetch": "^2.3.1",
    "redis": "^4.6.7"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.5.1",
    "@types/node-fetch": "^2.6.4",
    "nodemon": "^2.0.20",
    "typescript": "5.1.6"
  }
}
